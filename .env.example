
# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Public base URL of your Railway app (for webhook + static files)
# e.g. https://your-app.up.railway.app
WEBAPP_BASE_URL=https://your-app.up.railway.app

# Port (Railway sets PORT env automatically, default 8000)
PORT=8000

# Comma-separated list of admin Telegram IDs (optional, empty = everyone can create matches)
ADMIN_IDS=

# Mini App URL shown on the inline button (same as WEBAPP_BASE_URL + /miniapp)
MINIAPP_URL=https://your-app.up.railway.app/miniapp
